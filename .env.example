# Supabase — available at https://supabase.com/dashboard/project/<project-id>/settings/api
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon-public-key>

# Stripe — available at https://dashboard.stripe.com/apikeys (use test keys for dev)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Supabase project ID (used for Edge Function invocations)
VITE_SUPABASE_PROJECT_ID=<project-id>

# OpenAI — clé API utilisée en fallback si l'Edge Function scalyo-chat est indisponible
VITE_OPENAI_API_KEY=<your-openai-api-key>

# PostHog — https://posthog.com (optional, analytics disabled if not set)
VITE_POSTHOG_KEY=phc_...
VITE_POSTHOG_HOST=https://eu.i.posthog.com
